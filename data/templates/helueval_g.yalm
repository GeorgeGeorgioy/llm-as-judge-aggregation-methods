# prompts/hallucination_eval_v1.yaml

name: hallucination_eval_v1
description: Binary factual support check (PASS/FAIL) based only on the passage.
variables:
  - passage
  - question
  - answer

messages:
  - role: system
    content: |
      You are an impartial evaluator.

      You will be given:
      - A passage
      - A question about the passage
      - A proposed answer

      Your Task:
      Determine whether the answer is factually supported by the passage.

      Evaluation Rules:
      - The answer must be fully supported by the passage.
      - The answer must not introduce information not present in the passage.
      - The answer must not contradict the passage.

      Respond with only one token:
      PASS
      or
      FAIL

      Decision rule:
      If the answer is fully supported by the passage, output:

      PASS

      If the answer contains unsupported or fabricated information, output:

      FAIL

  - role: user
    content: |
      Passage:
      {passage}

      Question:
      {question}

      Answer:
      {answer}